---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<article class="project-card">
  <header class="project-card-header">
    <h3>{project.data.title}</h3>
    <p class="project-date">{project.data.date}</p>
  </header>
  <p class="project-role">{project.data.role}</p>
  <p>{project.data.description}</p>
  {
    project.data.metrics && project.data.metrics.length > 0 && (
      <ul class="project-metrics">
        {project.data.metrics.map((metric) => (
          <li>{metric}</li>
        ))}
      </ul>
    )
  }
  <ul class="project-tech">
    {project.data.tech.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
</article>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 0.9rem;
    background: var(--color-bg-secondary);
    padding: 1.2rem;
    display: grid;
    gap: 0.75rem;
  }

  .project-card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  h3 {
    margin: 0;
    color: var(--color-text-primary);
    font-size: 1.1rem;
  }

  .project-date {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .project-role {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .project-card p {
    margin: 0;
  }

  .project-metrics,
  .project-tech {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
  }

  .project-tech {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-tech li {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.83rem;
    color: var(--color-text-primary);
  }
</style>
