---
interface ExperienceItem {
  role: string;
  org: string;
  period: string;
  summary: string;
}

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<ol class="experience-timeline">
  {items.map((item) => (
    <li class="experience-item">
      <p class="experience-period terminal-brand">{item.period}</p>
      <h3>{item.role} @ {item.org}</h3>
      <p>{item.summary}</p>
    </li>
  ))}
</ol>

<style>
  .experience-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--color-border);
    display: grid;
    gap: 1rem;
  }

  .experience-item {
    margin-left: 1rem;
    padding: 0.2rem 0 0.2rem 1rem;
    border-left: 2px solid var(--color-accent);
  }

  .experience-period {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.86rem;
  }

  h3 {
    margin: 0.25rem 0;
    color: var(--color-text-primary);
    font-size: 1.05rem;
  }

  p {
    margin: 0;
  }
</style>
