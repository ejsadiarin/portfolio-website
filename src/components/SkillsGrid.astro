---
interface SkillsGroup {
  title: string;
  items: string[];
}

interface Props {
  groups: SkillsGroup[];
}

const { groups } = Astro.props;
---

<div class="skills-grid">
  {groups.map((group) => (
    <article class="skills-group">
      <h3>{group.title}</h3>
      <ul>
        {group.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  ))}
</div>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .skills-group {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem;
    background: var(--color-bg-secondary);
  }

  h3 {
    margin: 0 0 0.7rem;
    color: var(--color-text-primary);
    font-size: 1rem;
  }

  ul {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.3rem;
  }
</style>
