---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BlogPostCard from "../components/BlogPostCard.astro";
import { ContactForm } from "../components/ContactForm";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HomelabDiagram from "../components/HomelabDiagram.astro";
import HomelabServices from "../components/HomelabServices.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillsGrid from "../components/SkillsGrid.astro";
import { getFeaturedProjects, sortPostsByDateDesc } from "../lib/content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
const publishedPosts = await getCollection(
  "blog",
  (entry: CollectionEntry<"blog">) => !entry.data.draft,
);

const featuredProjects = getFeaturedProjects(projects).slice(0, 4);
const latestPosts = sortPostsByDateDesc(publishedPosts).slice(0, 3);

const experienceItems = [
  {
    role: "Lead Software Engineer",
    org: "La Salle Computer Society",
    period: "Aug 2025 - Current",
    summary:
      "Led platform engineering and backend delivery for internal systems and large-scale events.",
  },
  {
    role: "Technical Founder",
    org: "Thincode",
    period: "Dec 2025 - Current",
    summary:
      "Built automation workflows and client systems with a focus on cloud reliability and developer experience.",
  },
  {
    role: "Associate Vice President",
    org: "La Salle Computer Society",
    period: "Oct 2024 - Current",
    summary:
      "Directed engineering initiatives, mentorship tracks, and service-level reliability practices.",
  },
  {
    role: "SDE Intern",
    org: "Emerson",
    period: "Mar 2026 - Current",
    summary:
      "Supported backend and platform initiatives focused on observability, reliability, and scalable services.",
  },
];

const skillGroups = [
  {
    title: "Languages",
    items: ["Python", "Bash", "TypeScript", "Go", "Java", "SQL"],
  },
  {
    title: "Infrastructure and DevOps",
    items: [
      "Kubernetes",
      "Docker",
      "Terraform",
      "Ansible",
      "ArgoCD",
      "GitHub Actions",
    ],
  },
  {
    title: "Databases",
    items: ["PostgreSQL", "Redis", "MongoDB"],
  },
  {
    title: "Monitoring",
    items: ["Prometheus", "Grafana", "Jaeger", "Loki"],
  },
  {
    title: "AI and ML",
    items: ["NLP", "Agentic Workflows", "OpenAI APIs", "Google AI APIs"],
  },
];

const homelabServices = [
  {
    name: "GitOps Control Plane",
    description:
      "ArgoCD manages deployment state and rollback safety across internal services.",
  },
  {
    name: "Observability Stack",
    description:
      "Prometheus, Grafana, Jaeger, and Loki provide metrics, traces, and logs.",
  },
  {
    name: "Identity and Access",
    description:
      "Self-hosted identity services secure access for dashboards, APIs, and automation.",
  },
  {
    name: "Automation Services",
    description:
      "Scheduled jobs and event-based workers run backend operations and integrations.",
  },
];
---

<BaseLayout title="Ej Sadiarin" description="Software engineer portfolio">
  <Header />
  <main class="site-shell">
    <Hero />
    <section id="about" class="section">
      <div class="container section-stack">
        <h2>About</h2>
        <p>
          I am a software engineer from DLSU who enjoys designing reliable systems
          where infrastructure, backend development, and automation work together.
          My current work blends platform engineering with practical product
          delivery for teams that need speed without sacrificing resilience.
        </p>
        <p>
          I have led and shipped projects through LSCS and Thincode, and I am
          currently interning at Emerson while building production-style systems in
          my homelab. I am especially interested in DevOps, SRE, and AI-enabled
          workflows for developer productivity.
        </p>
        <p>
          Outside engineering, I train Taekwondo and CrossFit, enjoy coffee and
          tea, and spend a lot of weekends self-hosting and experimenting with new
          infra tools.
        </p>
      </div>
    </section>

    <section id="projects" class="section">
      <div class="container section-stack">
        <h2>Featured Projects</h2>
        <div class="card-grid">
          {featuredProjects.map((project: CollectionEntry<"projects">) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </div>
    </section>

    <section id="experience" class="section">
      <div class="container section-stack">
        <h2>Experience</h2>
        <ExperienceTimeline items={experienceItems} />
      </div>
    </section>

    <section id="skills" class="section">
      <div class="container section-stack">
        <h2>Skills</h2>
        <SkillsGrid groups={skillGroups} />
      </div>
    </section>

    <section id="homelab" class="section">
      <div class="container section-stack">
        <h2>Homelab</h2>
        <HomelabDiagram />
        <HomelabServices services={homelabServices} />
      </div>
    </section>

    <section id="blog" class="section">
      <div class="container section-stack">
        <h2>Blog Preview</h2>
        <div class="card-grid">
          {latestPosts.map((post: CollectionEntry<"blog">) => (
            <BlogPostCard post={post} />
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="section">
      <div class="container section-stack">
        <h2>Contact</h2>
        <ContactForm client:load />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .section-stack {
    display: grid;
    gap: 1rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  :global(.contact-form) {
    display: grid;
    gap: 1rem;
    max-width: 40rem;
  }

  :global(.field-group) {
    display: grid;
    gap: 0.5rem;
  }

  :global(.field-group label) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  :global(.field-group input),
  :global(.field-group textarea) {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.75rem;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    font-family: inherit;
  }

  :global(.field-group input:focus-visible),
  :global(.field-group textarea:focus-visible) {
    border-color: var(--color-accent);
    outline: none;
  }

  :global(.contact-form button) {
    width: fit-content;
    border: 1px solid var(--color-accent);
    border-radius: 0.5rem;
    padding: 0.65rem 1rem;
    background: transparent;
    color: var(--color-accent);
    font-weight: 600;
    cursor: pointer;
  }

  :global(.contact-form button:hover),
  :global(.contact-form button:focus-visible) {
    border-color: var(--color-accent-hover);
    color: var(--color-accent-hover);
  }

  :global(.form-error) {
    margin: 0;
    color: #f87171;
    font-size: 0.9rem;
  }

  :global(.contact-form a) {
    color: var(--color-accent);
  }

  :global(.contact-form a:hover),
  :global(.contact-form a:focus-visible) {
    color: var(--color-accent-hover);
  }
</style>
